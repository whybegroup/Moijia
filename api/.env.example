# Copy to `.env` in this folder (`cp .env.example .env`) and set values.
# `api/.env` is gitignored.

# Required for presigned uploads (S3UploadService)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Server access (private bucket is fine) ---
# The IAM user above authenticates with SigV4.
# Attach an IAM policy to that user, e.g.:
#   {
#     "Version": "2012-10-17",
#     "Statement": [{
#       "Effect": "Allow",
#       "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
#       "Resource": "arn:aws:s3:::YOUR_BUCKET/uploads/*"
#     }]
#   }
#   GetObject is required for POST /uploads/presign-get when objects are private.
# Leave "Block all public access" ON unless you intentionally want public objects.

# Optional: presigned GET TTL seconds (default 3600, max 604800 in code)
# S3_PRESIGN_GET_TTL_SECONDS=3600
#
# S3 console → bucket → Permissions → Cross-origin resource sharing (CORS), example:
# [{"AllowedHeaders":["*"],"AllowedMethods":["PUT","GET","HEAD"],"AllowedOrigins":["http://localhost:8081"],"ExposeHeaders":["ETag"]}]
# Add every origin your web app uses (Expo web port, production domain).
