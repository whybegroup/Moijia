# Copy to `.env` in this folder (`cp .env.example .env`) and set values.
# `api/.env` is gitignored.

# Public base URL the app uses to reach this API (for upload and image URLs).
# Example: http://192.168.1.5:3000 for a phone hitting your machine on LAN.
# API_PUBLIC_URL=http://localhost:3000

# Secret for signing one-shot PUT upload tokens (change in production).
# UPLOAD_PUT_SECRET=
