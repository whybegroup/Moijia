// Prisma Schema - Single source of truth for database
// Run: npm run db:migrate to create and apply migrations

datasource db {
  provider = "sqlite"
  url      = "file:./data/moija.db"
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// User Model
// ============================================

model User {
  id         String   @id @default(uuid())
  name       String
  displayName String
  avatarSeed String?  // DiceBear bottts seed for generated avatar
  thumbnail  String?  // Optional custom avatar image URL
  /// JSON: global in-app notification toggles (see NotifPrefs in API)
  notifPrefsJson String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  createdEvents           Event[]
  groupMemberships        GroupMember[]
  rsvps                   RSVP[]
  comments                Comment[]
  eventWatches            EventWatch[]
  eventActivityVotes      EventActivityVote[]
  authoredTimeSuggestions EventTimeSuggestion[] @relation("TimeSuggestionAuthor")
  createdActivityOptions  EventActivityOption[] @relation("ActivityOptionAuthor")

  @@map("users")
}

// ============================================
// Group Models
// ============================================

model Group {
  id         String    @id @default(uuid())
  name       String
  desc       String
  thumbnail  String?
  avatarSeed String?  // DiceBear icons seed for generated avatar
  inviteCode String?   @unique
  /// When true, new joins start as pending until an admin approves.
  requireApprovalToJoin Boolean @default(true)
  createdBy  String
  updatedBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  deletedBy  String?

  // Relations
  members     GroupMember[]
  events      Event[]
  coverPhotos GroupPhoto[]

  @@map("groups")
}

model GroupPhoto {
  id        Int      @id @default(autoincrement())
  groupId   String
  photoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_photos")
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   String
  userId    String
  role      String   @default("member") // member, admin, superadmin
  status    String   @default("active") // pending, active, rejected
  colorHex  String?  // User's custom color for this group
  /// JSON: per-group notification toggles (AND with user global prefs)
  notifPrefsJson String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

// ============================================
// Event Models
// ============================================

model Event {
  id           String    @id @default(uuid())
  groupId      String
  createdBy    String
  updatedBy    String
  title        String
  description  String?
  start        DateTime
  end          DateTime
  isAllDay       Boolean?  @default(false)
  location       String?
  minAttendees   Int?
  maxAttendees   Int?
  enableWaitlist Boolean?  @default(false)
  allowMaybe     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User         @relation(fields: [createdBy], references: [id])
  coverPhotos       EventPhoto[]
  rsvps             RSVP[]
  comments          Comment[]
  watches           EventWatch[]
  activityOptions   EventActivityOption[]
  activityVotes     EventActivityVote[]
  timeSuggestions   EventTimeSuggestion[]

  @@map("events")
}

model EventActivityOption {
  id        String   @id @default(uuid())
  eventId   String
  label     String
  createdBy String
  createdAt DateTime @default(now())

  event   Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator User                @relation("ActivityOptionAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  votes   EventActivityVote[]

  @@map("event_activity_options")
}

model EventActivityVote {
  id        String   @id @default(uuid())
  eventId   String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  event  Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  option EventActivityOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, optionId])
  @@map("event_activity_votes")
}

/// Group member proposes alternate start/end; host (or admin) may accept to update the event.
model EventTimeSuggestion {
  id          String   @id @default(uuid())
  eventId     String
  suggestedBy String
  start       DateTime
  end         DateTime
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  suggester User  @relation("TimeSuggestionAuthor", fields: [suggestedBy], references: [id], onDelete: Cascade)

  @@map("event_time_suggestions")
}

model EventPhoto {
  id        Int      @id @default(autoincrement())
  eventId   String
  photoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_photos")
}

// ============================================
// RSVP Model
// ============================================

model RSVP {
  id        Int      @id @default(autoincrement())
  eventId   String
  userId    String
  status    String   @default("notGoing") // going, maybe, notGoing, waitlist
  memo      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("rsvps")
}

// Explicit watch/follow for event notifications (overrides default: host + going + maybe)
model EventWatch {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  watching  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_watches")
}

// ============================================
// Comment Models
// ============================================

model Comment {
  id        String         @id @default(uuid())
  eventId   String
  userId    String
  text      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  event  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id])
  photos CommentPhoto[]

  @@map("comments")
}

model CommentPhoto {
  id        Int      @id @default(autoincrement())
  commentId String
  photoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("comment_photos")
}

// ============================================
// Notification Model
// ============================================

model Notification {
  id         String   @id @default(uuid())
  type       String
  read       Boolean  @default(false)
  ts         DateTime @default(now())
  icon       String
  title      String
  body       String
  groupId    String?
  eventId    String?
  navigable  Boolean  @default(false)
  dest       String?  // group, event
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notifications")
}
