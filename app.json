{
  "expo": {
    "name": "Popin",
    "slug": "popin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "popin",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAFAF9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.popin.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF9"
      },
      "package": "com.popin.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        { "photosPermission": "Popin needs access to your photos to share event memories." }
      ],
      [
        "expo-media-library",
        { "photosPermission": "Allow Popin to save photos.", "savePhotosPermission": "Allow Popin to save photos." }
      ]
    ]
  }
}
